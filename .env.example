# Server
PORT=5000
NODE_ENV=production

# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here

# SMTP Configuration (Titan Mail)
SMTP_HOST=smtp.titan.email
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=sales@jhitzone.com
SMTP_PASS=Sales@123
SMTP_FROM_NAME=JH IT Zone
SMTP_FROM_EMAIL=sales@jhitzone.com

# Google Custom Search (for lead extraction)
GOOGLE_API_KEY=your_google_api_key
GOOGLE_CX=your_custom_search_engine_id

# Follow-up Settings
FOLLOWUP_DAYS=3
MAX_FOLLOWUPS=3

# Rate Limiting
EMAIL_RATE_LIMIT_PER_HOUR=50
EMAIL_RATE_LIMIT_PER_DAY=500

# Database
DB_PATH=./data/leadgen.db
